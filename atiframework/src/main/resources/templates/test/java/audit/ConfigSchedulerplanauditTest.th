package com.bbva.[(${atiSettings.getUuaa().toLowerCase()})].audit;

import static org.junit.Assert.assertNotNull;

import com.bbva.[(${atiSettings.getUuaa().toLowerCase()})].[(${atiSettings.getServiceName().toLowerCase()})].audit.ConfigSchedulerplanaudit;
import org.junit.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.test.annotation.DirtiesContext;
import org.springframework.test.context.TestPropertySource;
import org.springframework.test.context.junit4.SpringJUnit4ClassRunner;

import com.bbva.gkxj.apirestgen.schedulerplanaudit.client.jaxrs.rest.impl.RestHandlerSchedulerplanaudit;
import com.bbva.kltt.apirest.generator.lib.commons.metadata.NovaMetadata;
import com.bbva.kltt.apirest.generator.lib.commons.client.request.NovaRequestConfig;

@SpringBootTest(classes = {ConfigSchedulerplanaudit.class})
@DirtiesContext
@ExtendWith(MockitoExtension.class)
@TestPropertySource(properties = {
    "microgateway.hostport.Schedulerplanaudit=localhost:24000",
    "microgateway.timeout.Schedulerplanaudit=10000",
    "release.header.Schedulerplanaudit=seguridad"
})
@RunWith(SpringJUnit4ClassRunner.class)
public class ConfigSchedulerplanauditTest {

    @MockBean
    private RestHandlerSchedulerplanaudit restHandlerSchedulerplanaudit;

    @InjectMocks
    @Autowired
    private ConfigSchedulerplanaudit configSchedulerplanaudit;

    @Test
    public void testGetRestHandlerSchedulerplanaudit() {
        RestHandlerSchedulerplanaudit restHandler = configSchedulerplanaudit.getRestHandlerSchedulerplanaudit();
        assertNotNull("RestHandlerSchedulerplanaudit should not be null", restHandler);
    }

    @Test
    public void testGetNovaMetadata() {
        NovaMetadata novaMetadata = configSchedulerplanaudit.getNovaMetadata();
        assertNotNull("NovaMetadata should not be null", novaMetadata);
        assertNotNull("NovaImplicitHeadersOutput should not be null", novaMetadata.getNovaImplicitHeadersOutput());
    }

    @Test
    public void testGetConfigRequestSchema() {
        NovaRequestConfig requestConfig = configSchedulerplanaudit.getConfigRequestSchema();
        assertNotNull("NovaRequestConfig should not be null", requestConfig);
    }
}