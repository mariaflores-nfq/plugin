asyncapi: 2.1.0
info:
  title: IssueAuditPublisher
  version: 2.0.0
  description: Channel frontToBack for saving IssueAudit
  contact:
    name: Utilidad para la Ingesta Transformacion y Exportacion de Datos
    url: https://novaxmas.cibdesktop.es.igrupobbva/novadashboard/#/products/Utilidad%20para%20la%20Ingesta%20Transformacion%20y%20Exportacion%20de%20Datos/12450220
    email: alberto.pina@bbva.com
  x-business-unit: gkxj

defaultContentType: application/json

channels:
  issueAuditChannel:
    description: Channel for saving IssueAudit
    publish:
      summary: Data necessary for saving IssueAudit
      operationId: publishIssueAudit
      message:
        $ref: '#/components/messages/issueAuditMessage'

components:
    messages:
      issueAuditMessage:
        name: issueAuditMessage
        title: issueAuditMessage
        summary: Data necessary for saving IssueAudit
        payload:
          $ref: '#/components/schemas/issueAuditPayload'
    schemas:
      issueAuditPayload:
        nodeType: object
        properties:
          uuaa:
            nodeType: string
            description: UUAA asociated to the audit
          issueAudit:
            $ref: '#/components/schemas/IssueAudit'

      IssueAudit:
        description: Issue Audit object returned by the service
        nodeType: object
        required:
        - _id
        - issueCode
        - issueDate
        - issueMessage
        - issueStatus
        - issueTechnicalCode
        properties:
          _id:
            nodeType: string
            description: Unique identifier in db
          uuaa:
            nodeType: string
            description: UUAA code associated to the issue
          status:
            nodeType: string
            description: Status of the issue (OPEN / CLOSED)
          issueClass:
            nodeType: string
            description: 'Class of the issue in runtime, example: NullPointerException'
          issueMessage:
            nodeType: string
            description: Message of the issue in runtime
          sourceSystem:
            nodeType: string
            description: Source system of the issue (Scheduler / Orchestator / Executor)
          executionId:
            nodeType: string
            description: Execution ID associated to the issue
          stepExecutionId:
            nodeType: string
            description: Step Execution ID associated to the issue
          schedulerId:
            nodeType: string
            description: Scheduler ID associated to the issue
          batchCode:
            nodeType: string
            description: Batch code associated to the issue
          stepCode:
            nodeType: string
            description: Step code associated to the issue
          serviceCode:
            nodeType: string
            description: Service code associated to the issue
          version:
            nodeType: string
            description: Version of the issue
          targetField:
            nodeType: string
            description: Target field of the issue
          targetValue:
            nodeType: string
            description: Target value of the issue
          groupCriteria:
            nodeType: string
            description: Group criteria of the issue
          generationTs:
            nodeType: string
            format: date-time
            description: Date when the issue was generated
          modificationTs:
            nodeType: string
            format: date-time
            description: Date when the issue was modified
          infoDataMap:
            description: Info data map with additional information
            nodeType: array
            items:
              $ref: '#/components/schemas/InfoDataMapItem'
          auditList:
            description: List of audits
            nodeType: array
            items:
              $ref: '#/components/schemas/Audit'
          issueTypeDetail:
            description: Issue nodeType detail
            $ref: '#/components/schemas/IssueTypeDetail'

      InfoDataMapItem:
        description: Info data map item
        nodeType: object
        required:
        - key
        - value
        properties:
          key:
            description: Key of the info data map
            nodeType: string
          value:
            description: Value with the info
            nodeType: string

      Audit:
        description: Audit object returned by the service
        nodeType: object
        properties:
          userId:
            description: UserId who made the audit action in the issue
            nodeType: string
          auditTs:
            nodeType: string
            format: date-time
            description: Date when the audit was made
          comment:
            nodeType: string
            description: Comment of the audit
          event:
            nodeType: string
            description: Event of the audit

      IssueTypeDetail:
        description: Issue nodeType detail
        nodeType: object
        properties:
          technicalCode:
            nodeType: string
            description: Technical code of the issue
          issueCode:
            nodeType: string
            description: Code of the issue
          issueDescription:
            nodeType: string
            description: Description of the issue
          assignedGroupRole:
            nodeType: string
            description: Assigned group role
          solutionList:
            description: List of solutions comments
            nodeType: array
            items:
              $ref: '#/components/schemas/Solution'

      Solution:
        description: Solution object returned by the service
        nodeType: object
        properties:
          userId:
            nodeType: string
            description: UserId who made the solution
          solution:
            nodeType: string
            description: Comment of the solution
          solutionTs:
            nodeType: string
            format: date-time
            description: Date when the solution was made


