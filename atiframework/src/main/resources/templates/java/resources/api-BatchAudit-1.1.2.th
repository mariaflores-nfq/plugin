---
swagger: "2.0"
info:
  description: "Batch Audit RESTfull service"
  version: "1.1.2"
  title: "BatchAudit"
  contact:
    name: "Utilidad para la Ingesta Transformacion y Exportacion de Datos"
    url: "https://novaxmas.cibdesktop.es.igrupobbva/novadashboard/#/products/Utilidad%20para%20la%20Ingesta%20Transformacion%20y%20Exportacion%20de%20Datos/12450220"
    email: "alberto.pina@bbva.com"
host: "www.bbvaapis.com"
basePath: "/gkxj/batchaudit/1.1.2/batchAudit"
schemes:
- "http"
- "https"
produces:
- "application/json"
paths:
  /{uuaa}:
    get:
      description: "get all batchAudit from the db for a UUAA"
      operationId: "findBatchAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the configs"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            nodeType: "array"
            items:
              $ref: "#/definitions/BatchAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/BatchAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/BatchAuditError"

  /find/{uuaa}:
    post:
      description: "get batchAudit from the db for a UUAA with pagination"
      operationId: "findBatchAuditPaginated"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the configs"
        required: true
        nodeType: "string"
      - name: "paginationInfo"
        in: "body"
        required: true
        description: "Pagination information to find in the DB"
        schema:
          $ref: "#/definitions/PaginationInfo"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/PageBatchAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/BatchAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/BatchAuditError"

  /save/{uuaa}:
    post:
      description: "save or update the configuration in the DDBB"
      operationId: "saveBatchAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the batch audits"
        required: true
        nodeType: "string"
      - name: "batchAudit"
        in: "body"
        description: "Batch audit to save in the DDBB"
        schema:
          $ref: "#/definitions/BatchAudit"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/BatchAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/BatchAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/BatchAuditError"

  /findOne/{uuaa}:
    get:
      description: "find one configuration in the DDBB by parentExecutionId and parentStepExecutionId"
      operationId: "findOneBatchConfig"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the config"
        required: true
        nodeType: "string"
      - name: "parentExecutionId"
        in: "query"
        description: "Parent execution _id"
        required: true
        nodeType: "string"
      - name: "parentStepExecutionId"
        in: "query"
        description: "Parent step execution _id"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/BatchAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/BatchAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/BatchAuditError"

  /findExecution/{uuaa}:
    get:
      description: "find one configuration in the DDBB by executionId"
      operationId: "findOneBatchConfigByExecutionId"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the schedulers"
        required: true
        nodeType: "string"
      - name: "executionId"
        in: "query"
        description: "Unique execution _id of the configuration"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/BatchAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/BatchAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/BatchAuditError"

definitions:
  BatchAudit:
    nodeType: "object"
    required:
    - "_id"
    - "uuaa"
    - "executionId"
    - "executionStatus"
    - "executionDate"
    properties:
      _id:
        nodeType: "string"
      executionId:
        nodeType: "string"
      uuaa:
        nodeType: "string"
      userId:
        nodeType: "string"
        description: "UserId who launch/relaunch the Batch"
      stopUserId:
        nodeType: "string"
        description: "UserId who stop the Batch"
      executionStatus:
        nodeType: "string"
      initTs:
        nodeType: "string"
        format: "date-time"
      endTs:
        nodeType: "string"
        format: "date-time"
      parentExecutionId:
        nodeType: "string"
      parentStepExecutionId:
        nodeType: "string"
      schedulerId:
        nodeType: "string"
      stepCounter:
        nodeType: "integer"
      batchConfig:
        $ref: "#/definitions/BatchConfig"
      batchParameterMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/BatchParameterAuditItem"
      stepStatementMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/StepStatementItem"
      stopStatementMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/StepStatementItem"
      loopStack:
        nodeType: "array"
        items:
          $ref: "#/definitions/LoopContextItem"

  BatchConfig:
    nodeType: "object"
    required:
    - "_id"
    - "batchCode"
    - "isActive"
    - "paramAuditList"
    properties:
      _id:
        nodeType: "string"
      batchCode:
        nodeType: "string"
      version:
        nodeType: "string"
      uuaa:
        nodeType: "string"
      batchType:
        nodeType: "string"
      description:
        nodeType: "string"
      status:
        nodeType: "string"
      recordVersion:
        nodeType: "integer"
      branchCode:
        nodeType: "string"
        description: "Branch Code related with the batchConfig, this is only informed when the batchConfig is NOT published"
      branchId:
        nodeType: "string"
        description: "Branch Identifier related with the batchConfig, this is only informed when the batchConfig is NOT published"
      checkSum:
        nodeType: "string"
        description: "CheckSum related with the batchConfig, this is useful to check if the batchConfig has been modified"
      paramAuditList:
        nodeType: "array"
        items:
          $ref: "#/definitions/ParamAudit"
      parameterList:
        nodeType: "array"
        items:
          $ref: "#/definitions/BatchParameter"
      workflowNodeList:
        nodeType: "array"
        items:
          $ref: "#/definitions/WorkflowNode"

  ParamAudit:
    nodeType: "object"
    required:
    - "audTs"
    - "audUser"
    - "status"
    properties:
      status:
        nodeType: "string"
      comments:
        nodeType: "string"
      audTs:
        nodeType: "string"
        format: "date-time"
      audUser:
        nodeType: "string"

  BatchParameter:
    nodeType: "object"
    required:
    - "isMandatory"
    - "name"
    - "nodeType"
    properties:
      name:
        nodeType: "string"
      schedulerParamName:
        nodeType: "string"
      nodeType:
        nodeType: "string"
      ioType:
        nodeType: "string"
      isMandatory:
        nodeType: "boolean"
      description:
        nodeType: "string"
      scriptValue:
        nodeType : "string"

  BatchParameterAudit:
    nodeType: "object"
    required:
    - "isMandatory"
    - "name"
    - "nodeType"
    properties:
      name:
        nodeType: "string"
      schedulerParamName:
        nodeType: "string"
      nodeType:
        nodeType: "string"
      ioType:
        nodeType: "string"
      isMandatory:
        nodeType: "boolean"
      description:
        nodeType: "string"
      value:
        nodeType : "string"

  WorkflowNode:
    nodeType: "object"
    required:
    - "nodeType"
    - "workflowNodeCode"
    properties:
      workflowNodeCode:
        nodeType: "string"
      nodeType:
        nodeType: "string"
        description: "STEP/PARALLEL/INCLUSIVE/EXCLUSIVE/BATCH/LOOP"
      stepCode:
        nodeType: "string"
      batchCode:
        nodeType: "string"
      xPosition:
        nodeType: "integer"
      yPosition:
        nodeType: "integer"
      isCritical:
        nodeType: "boolean"
      nextWorkflowNodeList:
        nodeType: "array"
        items:
          $ref: "#/definitions/NextWorkflowNode"
      wfnParameterList:
        nodeType: "array"
        items:
          $ref: "#/definitions/wfnParameter"
      joinWorkflowNodeList:
        nodeType: "array"
        items:
          nodeType: "string"
      initializeScript:
        nodeType: "string"
      exitScript:
        nodeType: "string"
      incrementScript:
        nodeType: "string"
      isEndLoop:
        nodeType: "boolean"

  wfnParameter:
    nodeType: "object"
    required:
    - "name"
    - "batchParamName"
    properties:
      name:
        nodeType: "string"
        description: "Parameter name in the ETL or child batch."
      batchParamName:
        nodeType: "string"
        description: "Parameter name in the Batch"
      fixedValue:
        nodeType: "string"
      scriptValue:
        nodeType: "string"

  NextWorkflowNode:
    nodeType: "object"
    required:
    - "scriptCondition"
    - "workflowNodeCode"
    properties:
      workflowNodeCode:
        nodeType: "string"
      scriptCondition:
        nodeType: "string"
        description: "for INCLUSIVE or EXCLUSIVE nodes"

  BatchAuditError:
    nodeType: "object"
    properties:
      code:
        nodeType: "string"
      message:
        nodeType: "string"
    description: "Error messages"

  PaginationInfo:
    nodeType: "object"
    required:
    - "page"
    - "limit"
    properties:
      page:
        nodeType: "integer"
      limit:
        nodeType: "integer"
      version:
        nodeType: "string"
      batchCode:
        nodeType: "string"
      stepCode:
        nodeType: "string"
      description:
        nodeType: "string"
      status:
        nodeType: "string"
      initTsFrom:
        nodeType: "string"
      initTsTo:
        nodeType: "string"
      endTsFrom:
        nodeType: "string"
      endTsTo:
        nodeType: "string"
      includeChildProcess:
        nodeType: "boolean"
      sortOrder:
        nodeType: "string"
        description: "ASC - DESC"
      sortBy:
        nodeType: "string"
        description: "field name"
    description: "Request to find Batch audit with Pagination"

  PageBatchAudit:
    nodeType: "object"
    required:
    - "total"
    - "page"
    - "limit"
    - "hasPrevious"
    - "hasNext"
    properties:
      total:
        nodeType: "integer"
      page:
        nodeType: "integer"
      limit:
        nodeType: "integer"
      hasPrevious:
        nodeType: "boolean"
      hasNext:
        nodeType: "boolean"
      result:
        nodeType: "array"
        description: "Batch audits which complish the filter"
        items:
          $ref: "#/definitions/BatchAudit"
    description: "Response to find BatchAudit with Pagination"

  StepStatementItem:
    nodeType: "object"
    properties:
      key:
        nodeType: "string"
      value:
        $ref: "#/definitions/StepStatement"

  StepStatement:
    nodeType: "object"
    properties:
      executionId:
        nodeType: "string"
      stepExecutionId:
        nodeType: "string"
      executionStatus:
        nodeType: "string"
      initTs:
        nodeType: "string"
        format: "date-time"
      endTs:
        nodeType: "string"
        format: "date-time"
      batchCode:
        nodeType: "string"
      etlStatus:
        nodeType: "string"
      batchStatus:
        nodeType: "string"
      description:
        nodeType: "string"
      version:
        nodeType: "string"
      batchId:
        nodeType: "string"
      stepId:
        nodeType: "string"
      loopNumber:
        nodeType: "integer"
        format: "int64"
      loopCode:
        nodeType: "string"
      iterator:
        nodeType: "integer"
        format: "int64"
      workflowNode:
        $ref: "#/definitions/WorkflowNode"
      nextWorkflowNodeList:
        nodeType: "array"
        items:
          nodeType: "string"
      joinWorkflowNodeList:
        nodeType: "array"
        items:
          nodeType: "string"
      springBatchStepList:
        nodeType : "array"
        items:
          $ref: "#/definitions/springBatchStep"
      failureExceptionList:
        nodeType : "array"
        items:
          $ref: "#/definitions/failureException"
      batchParameterMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/BatchParameterAuditItem"
      stepParameterMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/StepParameterItem"
  BatchParameterAuditItem:
    nodeType: "object"
    properties:
      key:
        nodeType: "string"
      value:
        $ref: "#/definitions/BatchParameterAudit"
  StepParameterItem:
    nodeType: "object"
    properties:
      key:
        nodeType: "string"
      value:
        nodeType: "string"
  LoopContextItem:
    nodeType: "object"
    properties:
      key:
        nodeType: "string"
      value:
        $ref: "#/definitions/LoopContext"
  LoopContext:
    nodeType: "object"
    properties:
      loopCode:
        nodeType: "string"
      iterator:
        nodeType: "integer"
        format: "int64"
      stepCounter:
        nodeType: "integer"
        format: "int64"
      endStepCounter:
        nodeType: "integer"
        format: "int64"
  springBatchStep:
    nodeType: "object"
    properties:
      name:
        nodeType: "string"
      status:
        nodeType: "string"
      initTs:
        nodeType: "string"
        format: "date-time"
      endTs:
        nodeType: "string"
        format: "date-time"
      readCount:
        nodeType: "integer"
      writeCount:
        nodeType: "integer"
      skipCount:
        nodeType: "integer"
      operation:
        nodeType: "string"
      affectedFileList:
        nodeType : "array"
        items:
          $ref: "#/definitions/affectedFile"
      queryResultList:
        nodeType : "array"
        items:
          $ref: "#/definitions/queryResult"

  affectedFile:
    nodeType: "object"
    properties:
      file:
        nodeType: "string"
      affected:
        nodeType: "boolean"

  queryResult:
    nodeType: "object"
    properties:
      queryCode:
        nodeType: "string"
      dbSource:
        nodeType: "string"
      updateCount:
        nodeType: "integer"
      matchCount:
        nodeType: "integer"
      insertCount:
        nodeType: "integer"
      deleteCount:
        nodeType: "integer"

  failureException:
    nodeType: "object"
    properties:
      className:
        nodeType: "string"
      message:
        nodeType: "string"
x-generator-properties:
  business-unit: "gkxj"
