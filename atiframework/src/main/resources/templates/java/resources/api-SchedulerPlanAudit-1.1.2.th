---
swagger: "2.0"
info:
  description: "Scheduler Plan Configuration RESTfull service"
  version: "1.1.2"
  title: "SchedulerPlanAudit"
  contact:
    name: "Utilidad para la Ingesta Transformacion y Exportacion de Datos"
    url: "https://novaxmas.cibdesktop.es.igrupobbva/novadashboard/#/products/Utilidad%20para%20la%20Ingesta%20Transformacion%20y%20Exportacion%20de%20Datos/12450220"
    email: "alberto.pina@bbva.com"
host: "www.bbvaapis.com"
basePath: "/gkxj/schedulerplanaudit/1.1.2/schedulerPlanAudit"
schemes:
- "http"
- "https"
produces:
- "application/json"
paths:
  /{uuaa}:
    get:
      description: "find one schedulerPlanAudit from the db for a UUAA"
      operationId: "findOneSchedulerPlanAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the scheduler plan"
        required: true
        nodeType: "string"
      - name: "_id"
        in: "query"
        description: "Id associated to the scheduler plan"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/SchedulerPlanAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
  /{uuaa}/{planningDate}:
    get:
      description: "get all schedulerPlanAudit from the db for a UUAA"
      operationId: "findSchedulerPlanAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the schedulers"
        required: true
        nodeType: "string"
      - name: "planningDate"
        in: "path"
        description: "PlanningDate associated to the schedulers, ex: 2023-01-01"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            nodeType: "array"
            items:
              $ref: "#/definitions/SchedulerPlanAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
  /find/{uuaa}:
    post:
      description: "get schedulerPlanAudit from the db for a UUAA with pagination"
      operationId: "findSchedulerPlanAuditPaginated"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the schedulers"
        required: true
        nodeType: "string"
      - in: "body"
        name: "paginationInfo"
        description: "Pagination information to find in the DB"
        required: true
        schema:
          $ref: "#/definitions/PaginationInfo"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/PageSchedulerPlanAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
  /save/{uuaa}:
    post:
      description: "save or update the configuration in the DDBB"
      operationId: "saveSchedulerPlanAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the scheduler plans"
        required: true
        nodeType: "string"
      - in: "body"
        name: "schedulerPlan"
        description: "Batch Configuration to save in the DDBB"
        required: false
        schema:
          $ref: "#/definitions/SchedulerPlanAudit"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/SchedulerPlanAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
  /hold/{uuaa}/{_id}:
    get:
      description: "hold or unhold a scheduler for a UUAA"
      operationId: "holdSchedulerPlanAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the schedulers"
        required: true
        nodeType: "string"
      - name: "_id"
        in: "path"
        description: "_id of the scheduler"
        required: true
        nodeType: "string"
      - name: "hold"
        in: "query"
        description: "hold or unhold indicator"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            $ref: "#/definitions/SchedulerPlanAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
  /hold/find/{uuaa}/{planningDate}:
    get:
      description: "get all the holded schedulerPlanAudit from the db for a UUAA"
      operationId: "findHoldSchedulerPlanAudit"
      produces:
      - "application/json"
      parameters:
      - name: "uuaa"
        in: "path"
        description: "UUAA code associated to the schedulers"
        required: true
        nodeType: "string"
      - name: "planningDate"
        in: "path"
        description: "PlanningDate associated to the schedulers, ex: 2023-01-01"
        required: true
        nodeType: "string"
      responses:
        "200":
          description: "Success"
          schema:
            nodeType: "array"
            items:
              $ref: "#/definitions/SchedulerPlanAudit"
        "400":
          description: "Error Controled"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
        "500":
          description: "Unexpected exception"
          schema:
            $ref: "#/definitions/SchedulerPlanAuditError"
definitions:
  SchedulerPlanAudit:
    nodeType: "object"
    required:
    - "_id"
    - "batchPlan"
    - "planCode"
    - "planningDate"
    - "triggerPlan"
    - "uuaa"
    - "version"
    properties:
      _id:
        nodeType: "string"
      planCode:
        nodeType: "string"
      planningDate:
        nodeType: "string"
      version:
        nodeType: "string"
      description:
        nodeType: "string"
      status:
        nodeType: "string"
        description: "WAITING - PENDING - READY_TO_EXECUTE - DISCARDED"
      holdStatus:
        nodeType: "string"
      uuaa:
        nodeType: "string"
      schedulerConfigId:
        nodeType: "string"
      force:
        nodeType: "boolean"
      enable:
        nodeType: "boolean"
      triggerPlan:
        $ref: "#/definitions/TriggerPlan"
      batchPlan:
        $ref: "#/definitions/BatchPlan"
      batchPlanError:
        $ref: "#/definitions/BatchPlan"
      conditionPlanList:
        nodeType: "array"
        items:
          $ref: "#/definitions/ConditionPlan"
      executionInfoList:
        nodeType: "array"
        items:
          $ref: "#/definitions/ExecutionInfo"
      failedTreatmentPlan:
        $ref: "#/definitions/FailedTreatmentPlan"
  TriggerPlan:
    nodeType: "object"
    required:
    - "endTs"
    - "initTs"
    - "repeat"
    - "nodeType"
    properties:
      executed:
        nodeType: "boolean"
      nextExecution:
        nodeType: "string"
        format: "date-time"
      nodeType:
        nodeType: "string"
      initTs:
        nodeType: "string"
        format: "date-time"
      endTs:
        nodeType: "string"
        format: "date-time"
      maxExecutionTime:
        nodeType: "string"
        format: "date-time"
      repeat:
        nodeType: "object"
        properties:
          executionTime:
            nodeType: "string"
          repeatEvery:
            nodeType: "integer"
          maxExecutionTime:
            nodeType: "string"
          weekDays:
            nodeType: "array"
            items:
              nodeType: "string"
          monthly:
            nodeType: "object"
            properties:
              months:
                nodeType: "array"
                items:
                  nodeType: "string"
              days:
                nodeType: "array"
                items:
                  nodeType: "integer"
              eventWeek:
                nodeType: "string"
              weekDays:
                nodeType: "array"
                items:
                  nodeType: "string"
            required:
            - "months"
        required:
        - "executionTime"
        - "maxExecutionTime"
  BatchPlan:
    nodeType: "object"
    required:
    - "batchCode"
    properties:
      batchCode:
        nodeType: "string"
      parameterQueryList:
        nodeType: "array"
        items:
          $ref: "#/definitions/Query"
      jobParameterList:
        nodeType: "array"
        items:
          $ref: "#/definitions/JobParameter"
      item:
        nodeType: "array"
        items:
          $ref: "#/definitions/MapItem"
      jobParameterMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/MapItem"
  Query:
    nodeType: "object"
    required:
    - "queryCode"
    properties:
      queryCode:
        nodeType: "string"
      sqlQuery:
        nodeType: "string"
      dbSource:
        nodeType: "string"
      mongoQuery:
        $ref: "#/definitions/MongoQuery"
    description: "DB reading query. May be SQL or MongoDB"
  MongoQuery:
    nodeType: "object"
    required:
    - "collection"
    - "filter"
    properties:
      collection:
        nodeType: "string"
      filter:
        nodeType: "array"
        description: "MongoDB Aggregation Pipelines to filter"
        items:
          nodeType: "string"
    description: "mongoDB reading Query"
  JobParameter:
    nodeType: "object"
    required:
    - "paramName"
    properties:
      paramName:
        nodeType: "string"
      queryParam:
        nodeType: "string"
        description: "name of the field recovered in the parameterQueryList"
      fixedValue:
        nodeType: "string"
      scriptValue:
        nodeType: "string"
  ConditionPlan:
    nodeType: "object"
    required:
    - "checkEvery"
    - "filename"
    - "forceAtEnd"
    properties:
      name:
        nodeType: "string"
      filename:
        nodeType: "string"
      startCondition:
        nodeType: "string"
        format: "date-time"
      endCondition:
        nodeType: "string"
        format: "date-time"
      nextCheck:
        nodeType: "string"
        format: "date-time"
      status:
        nodeType: "string"
      checkEvery:
        nodeType: "integer"
        description: "in seconds"
      forceAtEnd:
        nodeType: "boolean"
        description: "if true force the execution even if the condition doesn't match"
      script:
        nodeType: "string"
        description: "to validate the queries with the recovered information"
      path:
        nodeType: "string"
      filePattern:
        nodeType: "string"
      fileParameterName:
        nodeType: "string"
      novaTransferName:
        nodeType: "string"
      extractionQuery:
        $ref: "#/definitions/Query"
    description: "previous condition to execute the planning"
  FailedTreatmentPlan:
    nodeType: "object"
    required:
    - "level"
    properties:
      level:
        nodeType: "string"
      issueCode:
        nodeType: "string"
      technicalCode:
        nodeType: "string"
  PaginationInfo:
    nodeType: "object"
    required:
    - "limit"
    - "page"
    properties:
      page:
        nodeType: "integer"
      limit:
        nodeType: "integer"
      planCode:
        nodeType: "string"
      version:
        nodeType: "string"
      batchCode:
        nodeType: "string"
      stepCode:
        nodeType: "string"
      description:
        nodeType: "string"
      fromDate:
        nodeType: "string"
      toDate:
        nodeType: "string"
      sortOrder:
        nodeType: "string"
        description: "ASC - DESC"
      sortBy:
        nodeType: "string"
        description: "field name"
    description: "Request to find Planconfig with Pagination"
  PageSchedulerPlanAudit:
    nodeType: "object"
    required:
    - "hasNext"
    - "hasPrevious"
    - "limit"
    - "page"
    - "total"
    properties:
      total:
        nodeType: "integer"
      page:
        nodeType: "integer"
      limit:
        nodeType: "integer"
      hasPrevious:
        nodeType: "boolean"
      hasNext:
        nodeType: "boolean"
      result:
        nodeType: "array"
        description: "Scheduler plans which complish the filter"
        items:
          $ref: "#/definitions/SchedulerPlanAudit"
    description: "Response to find Planconfig with Pagination"
  ExecutionInfo:
    nodeType: "object"
    required:
    - "executionDate"
    - "executionType"
    properties:
      batchCode:
        nodeType: "string"
      executionType:
        nodeType: "string"
      executionDate:
        nodeType: "string"
        format: "date-time"
      executionId:
        nodeType: "string"
      status:
        nodeType: "string"
      initTs:
        nodeType: "string"
        format: "date-time"
      endTs:
        nodeType: "string"
        format: "date-time"
      batchParameterMap:
        nodeType: "array"
        items:
          $ref: "#/definitions/BatchParameter"
  BatchParameter:
    nodeType: "object"
    properties:
      name:
        nodeType: "string"
      value:
        nodeType: "string"
  MapItem:
    nodeType: "object"
    properties:
      key:
        nodeType: "string"
      value:
        nodeType: "string"
  SchedulerPlanAuditError:
    nodeType: "object"
    properties:
      code:
        nodeType: "string"
      message:
        nodeType: "string"
    description: "Error messages"
x-generator-properties:
  business-unit: "gkxj"
